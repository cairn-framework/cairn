{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "[ -f graphify-out/graph.json ] \u0026\u0026 echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true",
            "type": "command"
          }
        ],
        "matcher": "Glob|Grep"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(curl -sf http://127.0.0.1:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -sf http://localhost:*)",
      "Bash(curl * http://127.0.0.1:*)",
      "Bash(curl * http://localhost:*)"
    ]
  },
  "sandbox": {
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "127.0.0.1",
        "localhost"
      ]
    }
  }
}